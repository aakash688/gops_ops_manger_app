+    fs.readdirSync(outputDirectory).forEach(name => {
+      if (!name.endsWith('.h') && !name.endsWith('.cpp')) {
+        return;
+      }
+      const src = path.join(outputDirectory, name);
+      const dest = path.join(jniOutputDirectory, name);
+      let st;
+      try {
+        st = fs.lstatSync(src);
+      } catch (e) {
+        if (e && e.code === 'ENOENT') {
+          return;
+        }
+        throw e;
+      }
+      if (!st.isFile()) {
+        return;
+      }
+      if (fs.existsSync(dest)) {
+        fs.rmSync(dest, {force: true});
+      }
+      try {
+        fs.renameSync(src, dest);
+      } catch (e) {
+        // Windows: antivirus / parallel Gradle can make rename fail; copy+unlink is more reliable.
+        fs.copyFileSync(src, dest);
